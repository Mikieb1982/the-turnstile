{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "strict": false,
    "types": ["node", "handlebars"]
  },
  "include": ["src", "ai"],
  "exclude": ["node_modules", "dist", "genkit-crew"]
}
